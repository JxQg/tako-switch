{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tako Switch",
  "version": "0.4.0",
  "identifier": "com.tako.switch",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tako Switch",
        "width": 1220,
        "height": 820,
        "minWidth": 1080,
        "minHeight": 740
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "config/providers.json": "config/providers.json"
    },
    "icon": [
      "icons/icon.ico",
      "icons/icon.icns",
      "icons/128x128.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "takoswitch"
        ]
      }
    }
  }
}
